{
  "name": "@agentic-csv/application",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run tests/*.test.ts --passWithNoTests",
    "test:coverage": "vitest run tests/*.test.ts --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentic-csv/contracts": "workspace:*",
    "@agentic-csv/domain": "workspace:*"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
