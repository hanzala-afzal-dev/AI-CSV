{
  "name": "@agentic-csv/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run tests/*.test.ts --passWithNoTests",
    "test:coverage": "vitest run tests/*.test.ts --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentic-csv/contracts": "workspace:*",
    "@langchain/core": "1.2.1",
    "@langchain/langgraph": "1.4.7",
    "@langchain/openai": "1.5.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
