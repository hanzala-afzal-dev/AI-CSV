{
  "name": "agentic-csv-analyst",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.10.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:integration": "node --env-file-if-exists=.env node_modules/vitest/vitest.mjs run packages/infrastructure/tests/integration/rls.test.ts",
    "test:coverage": "turbo test:coverage",
    "architecture:check": "node scripts/check-architecture.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:key:create": "node --env-file=.env --import tsx scripts/create-api-key.ts",
    "infra:up": "docker compose --env-file .env -f docker/docker-compose.yml up -d postgres redis qdrant localstack",
    "infra:down": "docker compose --env-file .env -f docker/docker-compose.yml down",
    "infra:reset": "docker compose --env-file .env -f docker/docker-compose.yml down -v --remove-orphans",
    "docker:config": "docker compose --env-file .env -f docker/docker-compose.yml --profile app config",
    "docker:pull": "docker compose --env-file .env -f docker/docker-compose.yml pull postgres redis qdrant localstack",
    "docker:build": "docker compose --env-file .env -f docker/docker-compose.yml --profile app build web worker",
    "docker:up": "docker compose --env-file .env -f docker/docker-compose.yml --profile app up -d",
    "docker:up:build": "docker compose --env-file .env -f docker/docker-compose.yml --profile app up -d --build",
    "docker:rebuild": "docker compose --env-file .env -f docker/docker-compose.yml --profile app up -d --build --force-recreate",
    "docker:ps": "docker compose --env-file .env -f docker/docker-compose.yml --profile app ps",
    "docker:logs": "docker compose --env-file .env -f docker/docker-compose.yml --profile app logs -f --tail=200",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.yml --profile app down",
    "docker:reset": "docker compose --env-file .env -f docker/docker-compose.yml --profile app down -v --remove-orphans",
    "env:check": "node scripts/check-env.mjs",
    "quality": "pnpm format:check && pnpm architecture:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "quality:integration": "pnpm quality && pnpm test:integration"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@next/eslint-plugin-next": "16.2.10",
    "@types/node": "26.1.0",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.4",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
