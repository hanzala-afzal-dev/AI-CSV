# Copy this file to docker/stack.yml for local development.
# The copied docker/stack.yml file is intentionally gitignored so local
# Compose changes do not get committed.

name: agentic-csv-analyst

x-env-files: &env-files
  env_file:
    - ../.env
    - ./.env

services:
  postgres:
    image: pgvector/pgvector:pg17
    environment:
      POSTGRES_USER: "${POSTGRES_USER:?Set POSTGRES_USER in .env}"
      POSTGRES_PASSWORD: "${POSTGRES_PASSWORD:?Set POSTGRES_PASSWORD in .env}"
      POSTGRES_DB: "${POSTGRES_DB:?Set POSTGRES_DB in .env}"
      POSTGRES_APP_PASSWORD: "${POSTGRES_APP_PASSWORD:?Set POSTGRES_APP_PASSWORD in .env}"
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data
      - ./postgres/init:/docker-entrypoint-initdb.d:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U $${POSTGRES_USER} -d $${POSTGRES_DB}"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - agentic-csv

  redis:
    image: redis:8-alpine
    command: ["redis-server", "--appendonly", "yes", "--maxmemory-policy", "noeviction"]
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redis-data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - agentic-csv

  qdrant:
    image: qdrant/qdrant:v1.16.3
    ports:
      - "${QDRANT_PORT:-6333}:6333"
      - "${QDRANT_GRPC_PORT:-6334}:6334"
    volumes:
      - qdrant-data:/qdrant/storage
    healthcheck:
      test: ["CMD-SHELL", "bash -lc ': > /dev/tcp/127.0.0.1/6333'"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - agentic-csv

  localstack:
    image: localstack/localstack:4.11.1
    environment:
      SERVICES: "s3"
      DEBUG: "0"
      AWS_DEFAULT_REGION: "${S3_REGION:?Set S3_REGION in .env}"
      AWS_ACCESS_KEY_ID: "${S3_ACCESS_KEY_ID:?Set S3_ACCESS_KEY_ID in .env}"
      AWS_SECRET_ACCESS_KEY: "${S3_SECRET_ACCESS_KEY:?Set S3_SECRET_ACCESS_KEY in .env}"
      S3_BUCKET: "${S3_BUCKET:?Set S3_BUCKET in .env}"
    ports:
      - "${LOCALSTACK_PORT:-4566}:4566"
    volumes:
      - localstack-data:/var/lib/localstack
      - ./localstack/init:/etc/localstack/init/ready.d:ro
    healthcheck:
      test:
        [
          "CMD-SHELL",
          'curl -fs http://localhost:4566/_localstack/health | grep -Eq ''"s3": "(available|running)"'''
        ]
      interval: 10s
      timeout: 5s
      retries: 8
    networks:
      - agentic-csv

  mailpit:
    image: axllent/mailpit:v1.27.4
    ports:
      - "${SMTP_PORT:-1025}:1025"
      - "${MAILPIT_UI_PORT:-8025}:8025"
    healthcheck:
      test: ["CMD", "/mailpit", "readyz"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - agentic-csv

  web:
    <<: *env-files
    profiles: ["app"]
    init: true
    command: ["pnpm", "turbo", "dev", "--env-mode=loose", "--filter=@agentic-csv/web..."]
    build:
      context: ..
      dockerfile: docker/Dockerfile.web
      target: development
    ports:
      - "${APP_PORT:-3000}:3000"
    environment:
      # The app role is the only PostgreSQL credential available to web/worker.
      DATABASE_URL: "postgres://agentic_csv_app:${POSTGRES_APP_PASSWORD:?Set POSTGRES_APP_PASSWORD in .env}@postgres:5432/${POSTGRES_DB:?Set POSTGRES_DB in .env}"
      POSTGRES_USER: "agentic_csv_app"
      POSTGRES_PASSWORD: "${POSTGRES_APP_PASSWORD:?Set POSTGRES_APP_PASSWORD in .env}"
      POSTGRES_APP_PASSWORD: ""
      MIGRATION_DATABASE_URL: ""
      CHOKIDAR_USEPOLLING: "true"
      WATCHPACK_POLLING: "true"
      S3_PUBLIC_ENDPOINT: "http://localhost:${LOCALSTACK_PORT:-4566}"
      SMTP_HOST: "mailpit"
      SMTP_PORT: "1025"
    volumes:
      - ../apps/web/src:/app/apps/web/src:ro
      - ../apps/web/public:/app/apps/web/public:ro
      - ../apps/web/next.config.ts:/app/apps/web/next.config.ts:ro
      - ../apps/web/postcss.config.mjs:/app/apps/web/postcss.config.mjs:ro
      - ../packages/application/src:/app/packages/application/src:ro
      - ../packages/application/tsconfig.json:/app/packages/application/tsconfig.json:ro
      - ../packages/contracts/src:/app/packages/contracts/src:ro
      - ../packages/domain/src:/app/packages/domain/src:ro
      - ../packages/infrastructure/src:/app/packages/infrastructure/src:ro
      - ../packages/infrastructure/tsconfig.json:/app/packages/infrastructure/tsconfig.json:ro
      - ../packages/infrastructure/drizzle:/app/packages/infrastructure/drizzle:ro
    depends_on:
      migrate:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      qdrant:
        condition: service_healthy
      localstack:
        condition: service_healthy
      mailpit:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:3000/api/health >/dev/null"]
      interval: 15s
      timeout: 5s
      retries: 5
    networks:
      - agentic-csv

  migrate:
    profiles: ["app"]
    image: agentic-csv-analyst-worker
    command: ["./node_modules/.bin/drizzle-kit", "migrate"]
    environment:
      MIGRATION_DATABASE_URL: "postgres://${POSTGRES_USER:?Set POSTGRES_USER in .env}:${POSTGRES_PASSWORD:?Set POSTGRES_PASSWORD in .env}@postgres:5432/${POSTGRES_DB:?Set POSTGRES_DB in .env}"
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - ../packages/infrastructure/drizzle:/app/packages/infrastructure/drizzle:ro
    networks:
      - agentic-csv

  worker:
    <<: *env-files
    profiles: ["app"]
    init: true
    command:
      ["pnpm", "turbo", "dev", "--env-mode=loose", "--filter=@agentic-csv/worker..."]
    build:
      context: ..
      dockerfile: docker/Dockerfile.worker
      target: development
    image: agentic-csv-analyst-worker
    environment:
      DATABASE_URL: "postgres://agentic_csv_app:${POSTGRES_APP_PASSWORD:?Set POSTGRES_APP_PASSWORD in .env}@postgres:5432/${POSTGRES_DB:?Set POSTGRES_DB in .env}"
      POSTGRES_USER: "agentic_csv_app"
      POSTGRES_PASSWORD: "${POSTGRES_APP_PASSWORD:?Set POSTGRES_APP_PASSWORD in .env}"
      POSTGRES_APP_PASSWORD: ""
      MIGRATION_DATABASE_URL: ""
      CHOKIDAR_USEPOLLING: "true"
    volumes:
      - ../apps/worker/src:/app/apps/worker/src:ro
      - ../packages/application/src:/app/packages/application/src:ro
      - ../packages/application/tsconfig.json:/app/packages/application/tsconfig.json:ro
      - ../packages/contracts/src:/app/packages/contracts/src:ro
      - ../packages/domain/src:/app/packages/domain/src:ro
      - ../packages/infrastructure/src:/app/packages/infrastructure/src:ro
      - ../packages/infrastructure/tsconfig.json:/app/packages/infrastructure/tsconfig.json:ro
      - ../packages/infrastructure/drizzle:/app/packages/infrastructure/drizzle:ro
    depends_on:
      migrate:
        condition: service_completed_successfully
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      qdrant:
        condition: service_healthy
      localstack:
        condition: service_healthy
    stop_grace_period: 30s
    networks:
      - agentic-csv

networks:
  agentic-csv:
    driver: bridge

volumes:
  postgres-data:
  redis-data:
  qdrant-data:
  localstack-data:
