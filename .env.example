NODE_ENV=development
APP_NAME=Agentic CSV Analyst
APP_URL=http://localhost:3000
APP_PORT=3000
LOG_LEVEL=info
AUTH_SECRET=replace-with-a-local-development-secret
# Generate with: openssl rand -base64 32
APP_ENCRYPTION_KEY=replace-with-base64-encoded-32-byte-key
APP_ENCRYPTION_KEY_VERSION=v1
# JSON object used only while rotating old keys, for example {"v0":"base64-key"}
APP_ENCRYPTION_PREVIOUS_KEYS=
SESSION_COOKIE_NAME=agentic_csv_session
SESSION_IDLE_TTL_SECONDS=1800
SESSION_ABSOLUTE_TTL_SECONDS=604800
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
ARGON2_MEMORY_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
TRUST_PROXY=false
SMTP_HOST=localhost
SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Agentic CSV Analyst <no-reply@localhost>

POSTGRES_USER=agentic_csv
POSTGRES_PASSWORD=agentic_csv_password
POSTGRES_DB=agentic_csv
POSTGRES_PORT=5432
POSTGRES_APP_PASSWORD=agentic_csv_app_password
DATABASE_URL=postgres://agentic_csv_app:agentic_csv_app_password@localhost:5432/agentic_csv
MIGRATION_DATABASE_URL=postgres://agentic_csv:agentic_csv_password@localhost:5432/agentic_csv
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=5000

REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=agentic-csv
QUEUE_PREFIX=agentic-csv
WORKER_CONCURRENCY=2
QUEUE_JOB_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=5000

QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=knowledge_documents_v1
QDRANT_VECTOR_SIZE=1536

LOCALSTACK_PORT=4566
S3_ENDPOINT=http://localhost:4566
S3_PUBLIC_ENDPOINT=http://localhost:4566
S3_REGION=us-east-1
S3_BUCKET=agentic-csv-local
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true
UPLOAD_MAX_BYTES=104857600
PRESIGNED_URL_TTL_SECONDS=900
CSV_MAX_ROWS=1000000
CSV_MAX_COLUMNS=500
CSV_MAX_FIELD_CHARACTERS=1000000
CSV_MAX_MALFORMED_ROW_RATIO=0
CSV_PROFILE_TIMEOUT_MS=60000
DUCKDB_MEMORY_LIMIT_MB=512
INGESTION_CLAIM_TTL_SECONDS=300

OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_VALIDATION_TIMEOUT_MS=5000
DEFAULT_OPENAI_MODEL=gpt-5.5
DEFAULT_REASONING_EFFORT=medium
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-csv-local

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_AI_MAX_REQUESTS=20
RATE_LIMIT_LOGIN_MAX_REQUESTS=10
RATE_LIMIT_RECOVERY_MAX_REQUESTS=5
RATE_LIMIT_CREDENTIAL_VALIDATION_MAX_REQUESTS=5
RATE_LIMIT_CHAT_SUBMISSION_MAX_REQUESTS=20
RATE_LIMIT_SSE_CONNECTION_MAX_REQUESTS=30
RATE_LIMIT_UPLOAD_INTENT_MAX_REQUESTS=10
RATE_LIMIT_UPLOAD_COMPLETION_MAX_REQUESTS=20
SSE_MAX_CONNECTIONS_PER_USER=3
SSE_CONNECTION_LEASE_SECONDS=35

OTEL_SERVICE_NAME=agentic-csv-analyst
OTEL_EXPORTER_OTLP_ENDPOINT=
